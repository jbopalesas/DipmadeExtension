    <file src="..\bin\Release\DIPMADE.Extensions.pdb" target="lib\net48\" />
    <file src="..\bin\Release\DIPMADE.Extensions.xml" target="lib\net48\" />
    <file src="..\DIPMADE_Logo_fond.png" />
  </files>
</package>